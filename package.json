{
  "name": "patentchain",
  "version": "0.1.0",
  "private": true,
  "description": "PatentChain - Blockchain-based Patent Protection Platform",
  "scripts": {
    "dev": "cd frontend && npm run dev",
    "build": "cd frontend && npm run build",
    "start": "cd frontend && npm start",
    "backend:node": "cd backend && npm run node",
    "backend:compile": "cd backend && npm run compile",
    "backend:deploy": "cd backend && npm run deploy:all",
    "backend:deploy:registry": "cd backend && npm run deploy:local",
    "backend:deploy:crowdfunding": "cd backend && npm run deploy:crowdfunding",
    "backend:deploy:nft": "cd backend && npm run deploy:patent-nft",
    "install:all": "npm install && cd frontend && npm install && cd ../backend && npm install",
    "start:all": "start start-all.bat"
  },
  "workspaces": [
    "frontend",
    "backend"
  ],
  "keywords": [
    "blockchain",
    "patent",
    "nft",
    "ethereum",
    "hardhat",
    "nextjs"
  ],
  "license": "MIT"
}
